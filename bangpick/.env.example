# AI provider — 'qwen' (推荐，阿里通义千问免费层) | 'zhipu' | 'gemini' | 'minimax'
# ⚠️ Gemini 拒绝香港 IP，部署在 hkg1 region 会失败，国内首选 qwen
AI_PROVIDER=qwen

# 阿里通义千问 Qwen-Plus (推荐) — 注册送 100 万 tokens，国内直连稳
# 申请: https://bailian.console.aliyun.com → API-KEY 管理
DASHSCOPE_API_KEY=your-dashscope-api-key-here
# Optional: 默认 qwen-plus，可选 qwen-turbo / qwen-max
# QWEN_MODEL=qwen-plus

# 智谱 GLM-4.5-Flash (备用) — 永久免费，国内直连
# 申请: https://open.bigmodel.cn → 个人中心 → API Keys
ZHIPU_API_KEY=your-zhipu-api-key-here
# ZHIPU_MODEL=glm-4.5-flash

# Gemini (备用) — 注意：部署在 hkg1 会被 Google 拒绝
# 申请: https://aistudio.google.com/apikey  (免费 15 RPM, 1500 RPD)
GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-flash

# MiniMax (legacy fallback) — only needed when AI_PROVIDER=minimax
MINIMAX_API_KEY=your-minimax-api-key-here

# Local dev only: lets the front-end skip the proxy and call MiniMax directly
VITE_MINIMAX_API_KEY=your-minimax-api-key-here
