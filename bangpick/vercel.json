{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/stock-analyze.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/ip-location", "destination": "https://ipinfo.io/json" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
