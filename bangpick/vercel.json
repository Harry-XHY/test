{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/stock-analyze.js": { "maxDuration": 60 },
    "api/stock-hot-sectors.js": { "maxDuration": 30 },
    "api/stock-search.js": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/api/ip-location", "destination": "https://ipinfo.io/json" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
